      "com.asiantiertagger.AsianTierTaggerClient"
    ]
  },
  "mixins": [
    "asiantiertagger.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.11",
    "fabric-api": "*",
    "minecraft": "~1.21",
    "java": ">=21"
  }
