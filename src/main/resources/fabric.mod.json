  "authors": [
    "YourName"
  ],
  "contact": {
    "homepage": "https://github.com/yourname/AsianTierTagger",
    "sources": "https://github.com/yourname/AsianTierTagger"
  },
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
